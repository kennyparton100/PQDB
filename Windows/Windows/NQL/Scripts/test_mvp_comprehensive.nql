-- Test 6.4: Nested FOR + snapshot/restore stress test
PRINT 'Test 6.4: Deep nesting with snapshots'
LET deep = 0
SNAPSHOT deep_checkpoint

FOR i FROM 1 TO 5
    LET deep = deep + i
    IF i = 3 THEN
        SNAPSHOT inner_checkpoint
        LET deep = 100
        PRINT 'Set deep=100, now restoring inner'
        RESTORE inner_checkpoint
        PRINT 'After inner restore - deep:', deep
        PRINT 'EXPECT: After inner restore - deep: 6 (restored to pre-100 state)'
    END IF
END FOR

RESTORE deep_checkpoint
PRINT 'After final restore - deep:', deep
PRINT 'EXPECT: After final restore - deep: 0'
PRINT ''

