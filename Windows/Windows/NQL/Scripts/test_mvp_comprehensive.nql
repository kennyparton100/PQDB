-- ============================================================================
-- PHASE 1: Classes and Instances
-- ============================================================================

PRINT '-- Phase 1: Classes and Instances --'

-- Test 1.1: Create class, instantiate, set/get all field types
PRINT 'Test 1.1: Class creation and field access'
CLASS Person
    name : STRING
    age : INT
    height : FLOAT
END CLASS

LET p = NEW Person()
LET p.name = 'Alice'
LET p.age = 30
LET p.height = 5.6
PRINT 'name:', p.name, 'age:', p.age, 'height:', p.height
PRINT 'EXPECT: name: Alice age: 30 height: 5.6'
PRINT ''

-- Test 1.2: Default values are zero/false/empty for each type
PRINT 'Test 1.2: Default field values'
CLASS Defaults
    int_field : INT
    float_field : FLOAT
    bool_field : BOOL
    string_field : STRING
END CLASS

LET d = NEW Defaults()
PRINT 'INT:', d.int_field, 'FLOAT:', d.float_field, 'BOOL:', d.bool_field, 'STRING:', d.string_field
PRINT 'EXPECT: INT: 0 FLOAT: 0 BOOL: false STRING:'

LET d.int_field = 42
LET d.float_field = 3.14159
LET d.bool_field = true
LET d.string_field = 'test'
PRINT 'After set - INT:', d.int_field, 'FLOAT:', d.float_field, 'BOOL:', d.bool_field, 'STRING:', d.string_field
PRINT 'EXPECT: After set - INT: 42 FLOAT: 3.14159 BOOL: true STRING: test'
PRINT ''

-- Test 1.3: Two variables pointing to the same instance share state
PRINT 'Test 1.3: Reference semantics (shared instance)'
LET ref1 = NEW Person()
LET ref1.name = 'Bob'
LET ref2 = ref1
LET ref2.name = 'Charlie'
PRINT 'ref1.name:', ref1.name
PRINT 'EXPECT: ref1.name: Charlie (ref2 mutated the shared instance)'
PRINT ''

