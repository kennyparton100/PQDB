PRINT '-- Phase 8: Robustness Edge Cases --'

-- Test 8.1: Snapshot an array containing the same instance twice
PRINT 'Test 8.1: Snapshot array with aliased instance'
LET shared = NEW Person()
LET shared.name = 'Shared'
LET shared.age = 1
LET dup_arr = [shared, shared]
SNAPSHOT dup_snap

LET shared.name = 'Mutated'
LET shared.age = 99
PRINT 'Before restore - dup_arr[0].name:', dup_arr[0].name, 'dup_arr[1].name:', dup_arr[1].name
PRINT 'EXPECT: Before restore - dup_arr[0].name: Mutated dup_arr[1].name: Mutated'

RESTORE dup_snap
PRINT 'After restore - dup_arr[0].name:', dup_arr[0].name, 'dup_arr[1].age:', dup_arr[1].age
PRINT 'EXPECT: After restore - dup_arr[0].name: Shared dup_arr[1].age: 1'
PRINT ''

-- Test 8.2: Nested snapshots restored in different order (inner first, outer second)
PRINT 'Test 8.2: Nested snapshots, inner restored before outer'
LET nest_v = 0
SNAPSHOT outer_snap
LET nest_v = 10
SNAPSHOT inner_snap
LET nest_v = 20

PRINT 'Before any restore - nest_v:', nest_v
PRINT 'EXPECT: Before any restore - nest_v: 20'

RESTORE inner_snap
PRINT 'After inner restore - nest_v:', nest_v
PRINT 'EXPECT: After inner restore - nest_v: 10'

RESTORE outer_snap
PRINT 'After outer restore - nest_v:', nest_v
PRINT 'EXPECT: After outer restore - nest_v: 0'
PRINT ''

-- Test 8.3: ASSUMPTION_FAILED propagates up through nested function calls
PRINT 'Test 8.3: ASSUMPTION_FAILED deep in call stack'
LET deep_af = 'start'

CREATE FUNCTION inner_fail()
    ASSUMPTION_FAILED
    RETURN 'should_not_reach'
END FUNCTION

CREATE FUNCTION middle_call()
    LET x = inner_fail()
    RETURN x
END FUNCTION

ASSUME true THEN
    LET deep_af = 'in_assume'
    LET r83 = middle_call()
OTHERWISE
    PRINT 'OTHERWISE reached - deep_af:', deep_af
    PRINT 'EXPECT: OTHERWISE reached - deep_af: in_assume'
END ASSUME
PRINT ''

-- Test 8.4: Two different traits mapped to the same host field
PRINT 'Test 8.4: Overlapping trait field mappings'
CLASS Gauge
    reading : FLOAT
END CLASS

TRAIT Scalable
REQUIRES
    scale_val : FLOAT WRITE
END REQUIRES
CREATE FUNCTION scale(self, factor)
    LET self.scale_val = self.scale_val * factor
    RETURN self.scale_val
END FUNCTION
END TRAIT

TRAIT Offsetable
REQUIRES
    off_val : FLOAT WRITE
END REQUIRES
CREATE FUNCTION offset(self, delta)
    LET self.off_val = self.off_val + delta
    RETURN self.off_val
END FUNCTION
END TRAIT

MAP TRAIT Scalable TO Gauge AS GaugeScale
WITH
    scale_val -> reading
END MAP

MAP TRAIT Offsetable TO Gauge AS GaugeOffset
WITH
    off_val -> reading
END MAP

LET g = NEW Gauge()
LET g.reading = 10.0
LET r84a = GaugeScale.scale(g, 3.0)
PRINT 'After scale(3): reading:', g.reading, 'returned:', r84a
PRINT 'EXPECT: After scale(3): reading: 30 returned: 30'
LET r84b = GaugeOffset.offset(g, 5.0)
PRINT 'After offset(5): reading:', g.reading, 'returned:', r84b
PRINT 'EXPECT: After offset(5): reading: 35 returned: 35'
PRINT ''

-- Test 8.5: Restore after object mutation through an alias
PRINT 'Test 8.5: Restore reverts alias-visible mutations'
LET orig85 = NEW Person()
LET orig85.name = 'Original'
LET orig85.age = 10
LET alias85 = orig85

SNAPSHOT alias_mut_snap

LET alias85.name = 'AliasChanged'
LET alias85.age = 99
PRINT 'After alias mutation - orig85.name:', orig85.name, 'orig85.age:', orig85.age
PRINT 'EXPECT: After alias mutation - orig85.name: AliasChanged orig85.age: 99'

RESTORE alias_mut_snap
PRINT 'After restore - orig85.name:', orig85.name, 'orig85.age:', orig85.age
PRINT 'EXPECT: After restore - orig85.name: Original orig85.age: 10'
PRINT ''

-- Test 8.6: Snapshot + assume + restore inside OTHERWISE
PRINT 'Test 8.6: Snapshot/restore inside OTHERWISE'
LET v86 = 'init'

ASSUME false THEN
    LET v86 = 'should_not_run'
OTHERWISE
    SNAPSHOT ow_snap
    LET v86 = 'in_otherwise'
    PRINT 'In OTHERWISE before restore - v86:', v86
    PRINT 'EXPECT: In OTHERWISE before restore - v86: in_otherwise'
    RESTORE ow_snap
    PRINT 'In OTHERWISE after restore - v86:', v86
    PRINT 'EXPECT: In OTHERWISE after restore - v86: init'
END ASSUME
PRINT ''

-- Test 8.7: Assume chain where ALL conditions fail
PRINT 'Test 8.7: All-fail assume chain'
LET v87 = 'untouched'
ASSUME false THEN
    LET v87 = 'first'
OTHERWISE ASSUME false THEN
    LET v87 = 'second'
OTHERWISE ASSUME false THEN
    LET v87 = 'third'
OTHERWISE
    LET v87 = 'final_otherwise'
END ASSUME
PRINT 'v87:', v87
PRINT 'EXPECT: v87: final_otherwise'
PRINT ''

-- Test 8.8: Snapshot preserves scalar and array state together
PRINT 'Test 8.8: Snapshot with mixed scalars, arrays, and instances'
LET s_int = 42
LET s_str = 'hello'
LET s_arr = [1, 2, 3]
LET s_obj = NEW Person()
LET s_obj.name = 'SnapMix'

SNAPSHOT mix_snap

LET s_int = 999
LET s_str = 'changed'
LET s_arr = [9, 9, 9, 9]
LET s_obj.name = 'Mutated'

PRINT 'After mutation - int:', s_int, 'str:', s_str, 'arr len:', LENGTH(s_arr), 'obj:', s_obj.name
PRINT 'EXPECT: After mutation - int: 999 str: changed arr len: 4 obj: Mutated'

RESTORE mix_snap

PRINT 'After restore - int:', s_int, 'str:', s_str, 'arr len:', LENGTH(s_arr), 'obj:', s_obj.name
PRINT 'EXPECT: After restore - int: 42 str: hello arr len: 3 obj: SnapMix'
PRINT ''

