-- ============================================================================
-- PHASE 2: Traits and Mapped Functions
-- ============================================================================

PRINT '-- Phase 2: Traits and Mapped Functions --'

-- Test 2.1: Single trait function, verify slot-to-field remapping
PRINT 'Test 2.1: Trait function with slot remapping'
CLASS Point
    x : FLOAT
    y : FLOAT
END CLASS

TRAIT Translatable
REQUIRES
    tx : FLOAT WRITE
    ty : FLOAT WRITE
END REQUIRES

CREATE FUNCTION translate(self, dx, dy)
    LET self.tx = self.tx + dx
    LET self.ty = self.ty + dy
    RETURN true
END FUNCTION
END TRAIT

MAP TRAIT Translatable TO Point AS PointOps
WITH
    tx -> x,
    ty -> y
END MAP

LET pt = NEW Point()
LET pt.x = 10.0
LET pt.y = 20.0
PRINT 'Before: x:', pt.x, 'y:', pt.y
LET move_ok = PointOps.translate(pt, 5.0, 3.0)
PRINT 'After:  x:', pt.x, 'y:', pt.y, 'returned:', move_ok
PRINT 'EXPECT: After:  x: 15 y: 23 returned: true'
PRINT ''

-- Test 2.2: Two trait functions called sequentially, verify each step independently
PRINT 'Test 2.2: Multiple trait functions (step-by-step)'
TRAIT Calculable
REQUIRES
    value : FLOAT WRITE
    result : FLOAT WRITE
END REQUIRES

CREATE FUNCTION double_it(self)
    LET self.value = self.value * 2
    RETURN self.value
END FUNCTION

CREATE FUNCTION square_it(self)
    LET self.value = self.value * self.value
    LET self.result = self.value
    RETURN self.result
END FUNCTION
END TRAIT

CLASS Calculator
    input : FLOAT
    output : FLOAT
END CLASS

MAP TRAIT Calculable TO Calculator AS CalcOps
WITH
    value -> input,
    result -> output
END MAP

LET calc = NEW Calculator()
LET calc.input = 5.0
PRINT 'Initial input:', calc.input
PRINT 'EXPECT: Initial input: 5'

LET doubled = CalcOps.double_it(calc)
PRINT 'After double_it: input:', calc.input, 'returned:', doubled
PRINT 'EXPECT: After double_it: input: 10 returned: 10'

LET squared = CalcOps.square_it(calc)
PRINT 'After square_it: input:', calc.input, 'output:', calc.output, 'returned:', squared
PRINT 'EXPECT: After square_it: input: 100 output: 100 returned: 100'
PRINT ''

-- ============================================================================
-- PHASE 3: SNAPSHOT/RESTORE
-- ============================================================================

PRINT '-- Phase 3: SNAPSHOT/RESTORE --'

-- Test 3.1: Snapshot captures state, restore reverts it
PRINT 'Test 3.1: Basic snapshot and restore'
LET snap_var = 100
LET snap_obj = NEW Person()
LET snap_obj.name = 'Original'
LET snap_obj.age = 25

PRINT 'Before snapshot - var:', snap_var, 'name:', snap_obj.name
PRINT 'EXPECT: Before snapshot - var: 100 name: Original'

SNAPSHOT test_checkpoint

LET snap_var = 200
LET snap_obj.name = 'Modified'
LET snap_obj.age = 35

PRINT 'After modify - var:', snap_var, 'name:', snap_obj.name
PRINT 'EXPECT: After modify - var: 200 name: Modified'

RESTORE test_checkpoint

PRINT 'After restore - var:', snap_var, 'name:', snap_obj.name, 'age:', snap_obj.age
PRINT 'EXPECT: After restore - var: 100 name: Original age: 25'
PRINT ''

-- Test 3.2: Aliased references both revert on restore
PRINT 'Test 3.2: Alias preservation across snapshot/restore'
LET alias1 = NEW Person()
LET alias1.name = 'Shared'
LET alias2 = alias1
LET alias1.age = 40

SNAPSHOT alias_checkpoint

LET alias1.name = 'Changed'
LET alias1.age = 50
PRINT 'After modify - alias2.name:', alias2.name, 'alias2.age:', alias2.age
PRINT 'EXPECT: After modify - alias2.name: Changed alias2.age: 50'

RESTORE alias_checkpoint

PRINT 'After restore - alias1.name:', alias1.name, 'alias1.age:', alias1.age
PRINT 'After restore - alias2.name:', alias2.name, 'alias2.age:', alias2.age
PRINT 'EXPECT: Both revert to name: Shared age: 40'
PRINT ''

-- ============================================================================
-- PHASE 4: ASSUME/OTHERWISE (No Auto-Snapshot)
-- ============================================================================

PRINT '-- Phase 4: ASSUME/OTHERWISE --'

-- Test 4.1: True condition executes THEN body
PRINT 'Test 4.1: ASSUME true -> executes body'
LET a41 = 10
ASSUME a41 = 10 THEN
    LET a41 = 20
END ASSUME
PRINT 'a41:', a41
PRINT 'EXPECT: a41: 20'
PRINT ''

-- Test 4.2: False condition skips to OTHERWISE
PRINT 'Test 4.2: ASSUME false -> executes OTHERWISE'
LET a42 = 5
ASSUME a42 = 999 THEN
    LET a42 = 100
OTHERWISE
    LET a42 = 50
END ASSUME
PRINT 'a42:', a42
PRINT 'EXPECT: a42: 50'
PRINT ''

-- Test 4.3: Chained OTHERWISE ASSUME (else-if chain)
PRINT 'Test 4.3: Chained OTHERWISE ASSUME'
LET a43 = 'start'
ASSUME false THEN
    LET a43 = 'first'
OTHERWISE ASSUME false THEN
    LET a43 = 'second'
OTHERWISE ASSUME true THEN
    LET a43 = 'third'
END ASSUME
PRINT 'a43:', a43
PRINT 'EXPECT: a43: third'
PRINT ''

-- Test 4.4: ASSUMPTION_FAILED triggers OTHERWISE without auto-rollback
PRINT 'Test 4.4: ASSUMPTION_FAILED (no auto-rollback)'
LET a44 = 15
ASSUME true THEN
    LET a44 = 25
    ASSUMPTION_FAILED
OTHERWISE
    PRINT 'In OTHERWISE - a44:', a44
    PRINT 'EXPECT: In OTHERWISE - a44: 25 (mutation persists, no rollback)'
END ASSUME
PRINT ''

-- Test 4.5: Nested ASSUME blocks
PRINT 'Test 4.5: Nested ASSUME blocks'
LET outer = 'A'
LET inner = 'B'
ASSUME outer = 'A' THEN
    LET outer = 'A2'
    ASSUME inner = 'B' THEN
        LET inner = 'B2'
    END ASSUME
END ASSUME
PRINT 'outer:', outer, 'inner:', inner
PRINT 'EXPECT: outer: A2 inner: B2'
PRINT ''

-- Test 4.6: ACTIVE_ASSUMPTIONS() returns descriptions of live assumptions
PRINT 'Test 4.6: ACTIVE_ASSUMPTIONS() introspection'
LET a46 = 1
ASSUME a46 = 1 THEN
    ASSUME true THEN
        LET assumptions = ACTIVE_ASSUMPTIONS()
        PRINT 'Active count:', LENGTH(assumptions)
        PRINT 'EXPECT: Active count: 2'
    END ASSUME
END ASSUME
PRINT ''

-- ============================================================================
-- PHASE 5: Multi-Statement Functions
-- ============================================================================

PRINT '-- Phase 5: Multi-Statement Functions --'

-- Test 5.1: IF/ELSE branching inside a function
PRINT 'Test 5.1: Function with IF/ELSE'
CREATE FUNCTION complex_calc(x, y, z)
    LET result = x + y
    IF result > 10 THEN
        LET result = result * z
    ELSE
        LET result = result + z
    END IF
    RETURN result
END FUNCTION

LET r51 = complex_calc(5, 8, 3)
PRINT 'complex_calc(5,8,3):', r51
PRINT 'EXPECT: 39 (5+8=13 > 10, so 13*3=39)'
PRINT ''

-- Test 5.2: FOR loop with array indexing and early RETURN
PRINT 'Test 5.2: Function with FOR loop and early RETURN'
CREATE FUNCTION find_first(arr, target)
    FOR i FROM 0 TO LENGTH(arr) - 1
        IF arr[i] = target THEN
            RETURN i
        END IF
    END FOR
    RETURN -1
END FUNCTION

LET arr52 = [10, 20, 30, 40, 50]
LET found = find_first(arr52, 30)
LET miss = find_first(arr52, 99)
PRINT 'find_first([10..50], 30):', found
PRINT 'find_first([10..50], 99):', miss
PRINT 'EXPECT: 2 and -1'
PRINT ''

