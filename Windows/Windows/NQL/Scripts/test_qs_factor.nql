LET N = 1000000016000000063
LET t0 = TIMER_START()
PRINT 'QS Factoring N = ', N

LET tf = TRIAL_SMALL_FACTOR(N, 100000)
IF tf != NULL THEN
    PRINT 'Trivial: ', tf, ' x ', N / tf
END IF

IF tf = NULL THEN
    PRINT 'No trivial factor. Building factor base...'
    LET fb = FACTOR_BASE_BUILD(N, 10000, 64)
    IF fb != NULL THEN
        PRINT 'FB: ', FACTOR_BASE_SIZE(fb), ' primes, largest=', FACTOR_BASE_LARGEST(fb)
        LET rels = RELATION_SET_CREATE(FACTOR_BASE_SIZE(fb))
        LET sieve = QS_SIEVE_CREATE(16384)
        LET s = INT_SQRT(N) + 1
        LET threshold = LOG2(FACTOR_BASE_LP_BOUND(fb)) + 1.0
        LET found = 0
        LET target_rels = FACTOR_BASE_SIZE(fb) + 30
        PRINT 'Target rels: ', target_rels, ', threshold: ', threshold
        FOR poly FROM 0 TO 128 DO
            LET center = s + poly * 16384
            LET sieve = QS_SIEVE_INIT(sieve, N, center)
            LET sieve = QS_SIEVE_RUN(sieve, fb, center)
            LET cands = QS_SIEVE_CANDIDATES(sieve, threshold)
            FOR EACH xi IN cands DO
                LET xoff = xi - 16384
                LET xc = xoff + center
                IF xc > 0 THEN
                    LET Qx = xc * xc - N
                    IF Qx > 0 THEN
                        LET tr = TRIAL_FACTOR_CANDIDATE(Qx, fb, xc, 0)
                        IF tr != NULL THEN
                            IF TRIAL_RESULT_IS_SMOOTH(tr) THEN
                                LET rels = RELATION_SET_ADD(rels, tr)
                            END IF
                            IF TRIAL_RESULT_IS_PARTIAL(tr) THEN
                                LET rels = RELATION_SET_ADD(rels, tr)
                            END IF
                        END IF
                    END IF
                END IF
            END FOR
            IF RELATION_SET_COUNT(rels) >= target_rels THEN
                PRINT 'Enough relations at poly ', poly
                BREAK
            END IF
            IF poly % 20 = 0 THEN
                PRINT 'poly ', poly, ': ', RELATION_SET_COUNT(rels), ' rels'
            END IF
        END FOR
        PRINT 'Collected: ', RELATION_SET_COUNT(rels), ' relations'
        LET rels = RELATION_SET_PRUNE_SINGLETONS(rels)
        PRINT 'After pruning: ', RELATION_SET_COUNT(rels)
        IF RELATION_SET_COUNT(rels) > FACTOR_BASE_SIZE(fb) THEN
            LET matrix = GF2_MATRIX_BUILD(rels)
            LET matrix = GF2_ELIMINATE(matrix)
            LET ns = GF2_NULLSPACE_COUNT(matrix)
            PRINT 'Rank: ', GF2_RANK(matrix), ', nullspace: ', ns
            FOR i FROM 0 TO ns - 1 DO
                LET dep = GF2_NULLSPACE_VECTOR(matrix, i)
                IF dep != NULL THEN
                    LET g = DEPENDENCY_EXTRACT(dep, rels, fb, N)
                    IF g != NULL THEN
                        IF g > 1 THEN
                            IF g < N THEN
                                PRINT 'FACTOR: ', g, ' x ', N / g
                                LET found = g
                                BREAK
                            END IF
                        END IF
                    END IF
                END IF
            END FOR
            IF found <= 1 THEN
                PRINT 'Trying pairwise...'
                FOR i FROM 0 TO ns - 2 DO
                    FOR j FROM i + 1 TO ns - 1 DO
                        LET d1 = GF2_NULLSPACE_VECTOR(matrix, i)
                        LET d2 = GF2_NULLSPACE_VECTOR(matrix, j)
                        IF d1 != NULL THEN
                            IF d2 != NULL THEN
                                LET dep = DEPENDENCY_COMBINE(d1, d2)
                                LET g = DEPENDENCY_EXTRACT(dep, rels, fb, N)
                                IF g != NULL THEN
                                    IF g > 1 THEN
                                        IF g < N THEN
                                            PRINT 'FACTOR: ', g, ' x ', N / g
                                            LET found = g
                                            BREAK
                                        END IF
                                    END IF
                                END IF
                            END IF
                        END IF
                    END FOR
                    IF found > 1 THEN
                        BREAK
                    END IF
                END FOR
            END IF
        ELSE
            PRINT 'Not enough relations'
        END IF
    ELSE
        PRINT 'FB build failed'
    END IF
END IF
PRINT 'Time: ', TIMER_ELAPSED(t0), 's'
