-- Simple Phase 4 Test
PRINT '=== Simple ASSUME Test ==='

-- Test 1: Basic ASSUME with true condition
LET x = 10
PRINT 'Before ASSUME x:', x

ASSUME x = 10 THEN LET x = 20 PRINT 'Inside ASSUME x:', x END ASSUME

PRINT 'After ASSUME x:', x

-- Test 2: Array literal
LET arr = [1, 2, 3]
PRINT 'Array:', arr

-- Test 3: Simple ASSUMPTION_FAILED
ASSUME true THEN LET y = 5 ASSUMPTION_FAILED END ASSUME
PRINT 'This should not execute'
